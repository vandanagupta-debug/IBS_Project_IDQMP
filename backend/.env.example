# Copy this file to .env and fill in real values for local development.
# In Docker Compose, these are instead supplied via the `environment:` block.

APP_NAME=IBS Data Quality Platform
APP_VERSION=1.0.0
DEBUG=True

HOST=0.0.0.0
PORT=8000

# postgresql://<user>:<password>@<host>:<port>/<db>
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ibs_dqp

SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Optional - only required if AI-assisted features are used
OPENAI_API_KEY=